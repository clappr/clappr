{
  "name": "@clappr/telemetry",
  "version": "0.1.0",
  "description": "Telemetry package for Clappr player",
  "main": "./dist/clappr-telemetry.js",
  "module": "./dist/clappr-telemetry.esm.js",
  "scripts": {
    "bundle-check": "ANALYZE_BUNDLE=true rollup --config --bundleConfigAsCjs",
    "release": "MINIMIZE=true rollup --config --bundleConfigAsCjs",
    "build": "rollup --config --bundleConfigAsCjs",
    "watch": "rollup --config --watch --bundleConfigAsCjs",
    "test": "jest src/",
    "test:coverage": "open coverage/lcov-report/index.html",
    "test:debug": "node --inspect node_modules/.bin/jest src/ --runInBand",
    "test:watch": "jest /src --watch",
    "lint": "eslint *.js src/",
    "lint:fix": "npm run lint -- --fix",
    "start": "DEV=true rollup --config --watch --bundleConfigAsCjs",
    "dev": "DEV=true rollup --config --watch --bundleConfigAsCjs",
    "prepublishOnly": "lerna run release --scope=@clappr/telemetry"
  },
  "files": [
    "/dist",
    "/src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:clappr/clappr-telemetry.git"
  },
  "author": "Globo.com",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/clappr/clappr-telemetry/issues"
  },
  "homepage": "https://github.com/clappr/clappr-telemetry",
  "peerDependencies": {
    "@clappr/core": "*"
  },
  "devDependencies": {
    "@babel/core": "^7.22.17",
    "@babel/preset-env": "^7.22.15",
    "@clappr/core": "^0.13.1",
    "@rollup/plugin-commonjs": "^28.0.8",
    "@rollup/plugin-node-resolve": "^15.2.1",
    "@rollup/plugin-replace": "^5.0.2",
    "babel-jest": "^30.2.0",
    "eslint": "^8.49.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "rollup": "^3.29.1",
    "rollup-plugin-analyzer": "^4.0.0",
    "rollup-plugin-babel": "^4.4.0",
    "rollup-plugin-filesize": "^10.0.0",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-serve": "^2.0.2",
    "rollup-plugin-terser": "^7.0.2"
  }
}
